# oauth2-proxy environment — written by auth/authentik_bootstrap.py.
# Copy to ~/.config/sonos-scheduler/oauth2-proxy.env (mode 0600). NEVER commit real values.
#
# Client credentials of the OIDC provider (Authentik application "sonos-scheduler"):
OAUTH2_PROXY_CLIENT_ID=sonos-scheduler
OAUTH2_PROXY_CLIENT_SECRET=replace-me
# 16/24/32 raw bytes. Generate: head -c 24 /dev/urandom | base64 | tr '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=replace-me-32-chars
# Per-provider issuer and the callback registered in the provider's redirect URIs:
OAUTH2_PROXY_OIDC_ISSUER_URL=https://auth.example.com/application/o/sonos-scheduler/
OAUTH2_PROXY_REDIRECT_URL=http://YOUR_HOST_IP:8095/oauth2/callback
